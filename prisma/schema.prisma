generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ProblemType {
  OOD
  API
  SYSTEM_DESIGN
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ProgrammingLanguage {
  JAVASCRIPT
  PYTHON
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String?
  email             String    @unique
  image             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  interviewSessions Session[]
  submissions       Submission[]
}

model Session {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  status           SessionStatus     @default(ACTIVE)
  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemInstances ProblemInstance[]
  submissions      Submission[]

  @@index([userId])
}

model ProblemTemplate {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String            @unique
  type             ProblemType
  basePrompt       String
  variants         String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  problemInstances ProblemInstance[]
}

model ProblemInstance {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  sessionId        String             @db.ObjectId
  templateId       String             @db.ObjectId
  generatedPrompt  String
  selectedVariants String[]
  generationParams Json?
  savedCode        Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  session          Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template         ProblemTemplate    @relation(fields: [templateId], references: [id])
  submissions      Submission[]

  @@index([sessionId])
}

model Submission {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  sessionId         String              @db.ObjectId
  problemInstanceId String              @db.ObjectId
  language          ProgrammingLanguage
  code              String
  result            Json
  status            SubmissionStatus    @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problemInstance   ProblemInstance     @relation(fields: [problemInstanceId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([problemInstanceId])
}
