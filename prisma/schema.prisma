generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProblemType {
  OOD
  API
  SYSTEM_DESIGN
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ProgrammingLanguage {
  JAVASCRIPT
  PYTHON
}

model User {
  id              String             @id @default(cuid())
  name            String?
  email           String             @unique
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  interviewSessions Session[]
  submissions     Submission[]
}

model Session {
  id               String            @id @default(cuid())
  userId           String
  status           SessionStatus     @default(ACTIVE)
  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemInstances ProblemInstance[]
  submissions      Submission[]
}

model ProblemTemplate {
  id               String            @id @default(cuid())
  name             String            @unique
  type             ProblemType
  basePrompt       String
  variants         String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  problemInstances ProblemInstance[]
}

model ProblemInstance {
  id               String             @id @default(cuid())
  sessionId        String
  templateId       String
  generatedPrompt  String
  selectedVariants String[]
  generationParams Json?
  savedCode        Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  session          Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template         ProblemTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  submissions      Submission[]
}

model Submission {
  id                String              @id @default(cuid())
  userId            String
  sessionId         String
  problemInstanceId String
  language          ProgrammingLanguage
  code              String
  result            Json
  status            SubmissionStatus    @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problemInstance   ProblemInstance     @relation(fields: [problemInstanceId], references: [id], onDelete: Cascade)
}
